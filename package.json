{
  "name": "horoscopefree",
  "version": "0.0.1",
  "description": "Multilingual horoscope data library and HTTP API",
  "type": "module",
  "license": "MIT",
  "author": "Vitor Emanuel Batista",
  "engines": {
    "node": ">=22.18.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "lint": "eslint src test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hono/node-server": "1.19.13",
    "cheerio": "1.2.0",
    "hono": "4.12.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "4.1.2",
    "eslint": "^10.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.21.0",
    "typescript": "6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "4.1.2"
  }
}
